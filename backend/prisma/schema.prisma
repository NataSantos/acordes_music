generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "sqlite"
}

model Sala {
  id         String   @id @default(uuid())
  nome       String
  capacidade Int

  descricao  String?
}

model Usuario {
  id        String    @id @default(uuid())
  cpf       Int       @unique
  nome      String
  telefone  Int
  funcao    String 

  civil     String?
  endereco  String?
  profissao String?

  createdAt DateTime  @default(now())
}